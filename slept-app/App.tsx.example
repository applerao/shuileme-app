/**
 * App.tsx - 睡了么 App 入口文件
 * 
 * 包含微信登录完整集成示例
 */

import React, { useEffect, useState } from 'react';
import { NavigationContainer } from '@react-navigation/native';
import { createStackNavigator } from '@react-navigation/stack';
import { View, ActivityIndicator, StyleSheet } from 'react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';

// 导入登录注册页面
import { LoginScreen, RegisterScreen } from './src';

// 导入微信登录工具
import { initWeChat } from './src/utils/wechat';

// 导入主题
import { colors } from './src/styles/theme';

// 导入其他页面（根据实际需求）
// import HomeScreen from './src/screens/HomeScreen';
// import SleepTrackingScreen from './src/screens/SleepTrackingScreen';

const Stack = createStackNavigator();

export default function App() {
  const [isWeChatInitialized, setIsWeChatInitialized] = useState(false);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    // 应用启动时初始化
    const initialize = async () => {
      try {
        // 1. 初始化微信 SDK
        const wechatSuccess = await initWeChat();
        console.log('微信 SDK 初始化:', wechatSuccess ? '成功' : '失败');

        // 2. 检查登录状态
        const token = await AsyncStorage.getItem('user_token');
        console.log('登录状态:', token ? '已登录' : '未登录');

        setIsWeChatInitialized(wechatSuccess);
      } catch (error) {
        console.error('初始化失败:', error);
      } finally {
        setIsLoading(false);
      }
    };

    initialize();
  }, []);

  // 处理登录
  const handleLogin = async (phone: string, password: string) => {
    try {
      // TODO: 调用后端登录接口
      const response = await fetch('https://api.shuileme.com/api/v1/auth/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          phone,
          password,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.message || '登录失败');
      }

      const data = await response.json();
      
      // 保存 token
      await AsyncStorage.setItem('user_token', data.token);
      await AsyncStorage.setItem('user_info', JSON.stringify(data.userInfo));
      
      console.log('登录成功:', data.userInfo);
    } catch (error: any) {
      console.error('登录失败:', error);
      throw error;
    }
  };

  // 处理微信登录
  const handleWechatLogin = async () => {
    try {
      // 微信登录的具体逻辑在 LoginScreen 中已处理
      // 这里可以添加额外的业务逻辑
      console.log('微信登录回调');
    } catch (error: any) {
      console.error('微信登录失败:', error);
      throw error;
    }
  };

  // 处理注册
  const handleRegister = async (
    phone: string,
    code: string,
    password: string,
    confirmPassword: string
  ) => {
    try {
      // TODO: 调用后端注册接口
      const response = await fetch('https://api.shuileme.com/api/v1/auth/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          phone,
          code,
          password,
          confirmPassword,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.message || '注册失败');
      }

      const data = await response.json();
      console.log('注册成功:', data);
    } catch (error: any) {
      console.error('注册失败:', error);
      throw error;
    }
  };

  // 加载页面
  if (isLoading) {
    return (
      <View style={styles.loadingContainer}>
        <ActivityIndicator size="large" color={colors.primary} />
      </View>
    );
  }

  return (
    <NavigationContainer>
      <Stack.Navigator screenOptions={{ headerShown: false }}>
        <Stack.Screen name="Login">
          {(props) => (
            <LoginScreen
              onLogin={handleLogin}
              onWechatLogin={handleWechatLogin}
              onNavigateToRegister={() => {
                props.navigation.navigate('Register');
              }}
            />
          )}
        </Stack.Screen>
        <Stack.Screen name="Register">
          {(props) => (
            <RegisterScreen
              onRegister={handleRegister}
              onNavigateToLogin={() => {
                props.navigation.navigate('Login');
              }}
            />
          )}
        </Stack.Screen>
        {/* 
        // 登录后的主页面
        <Stack.Screen name="Home" component={HomeScreen} />
        <Stack.Screen name="SleepTracking" component={SleepTrackingScreen} />
        */}
      </Stack.Navigator>
    </NavigationContainer>
  );
}

const styles = StyleSheet.create({
  loadingContainer: {
    flex: 1,
    justifyContent: 'center',
    alignItems: 'center',
    backgroundColor: colors.background,
  },
});
